NODE_ENV=production
VERSION=os

# 对外访问地址，不要带结尾斜杠
DOMAIN=http://your-server-ip-or-domain
PUBLIC_HTTP_PORT=80

MONGO_URL=mongodb://mongo:27017/erxes
REDIS_HOST=redis
REDIS_PORT=6379

ENABLED_PLUGINS=operation,sales,frontline,china_leads
CHINA_LEADS_EXECUTOR_URL=http://your-executor-host:4318

# 不填时脚本会自动按 DOMAIN 推导
# CHINA_LEADS_UI_ENTRY_URL=http://your-server-ip-or-domain/plugins/china_leads_ui/remoteEntry.js
# REACT_APP_API_URL=http://your-server-ip-or-domain/gateway

# 可选：抓到线索后默认分配给哪些销售，逗号分隔用户 ID
# CHINA_LEADS_ASSIGNED_USER_IDS=

# 可选：默认落到哪个销售阶段
# CHINA_LEADS_DEFAULT_STAGE_ID=

# 低配服务器可选：
# DEPLOY_LOW_MEMORY=1
# DEPLOY_SWAP_MB=4096
# DEPLOY_SKIP_SWAP=1
